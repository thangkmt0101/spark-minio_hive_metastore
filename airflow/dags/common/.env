# Thông tin NiFi (xác thực bằng client cert PEM — xem NIFI_CLIENT_* bên dưới)
NIFI_URL=https://10.110.33.32:8443/nifi-api

# mTLS: file PEM sau khi convert từ .p12 (requests không dùng trực tiếp .p12)
# Trong container Airflow: mount thư mục certs vào /opt/airflow/dags/common/certs
NIFI_CLIENT_CERT_PEM_PATH=/opt/airflow/dags/common/certs/nifi-client-cert.pem
NIFI_CLIENT_KEY_PEM_PATH=/opt/airflow/dags/common/certs/nifi-client-key.pem
 

# Thông tin kết nối PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=etl_db
POSTGRES_USER=etl_user
POSTGRES_PASSWORD=your_password_here



